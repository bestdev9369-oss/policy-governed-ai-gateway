# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://pgag:pgag_dev@localhost:5432/pgag

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── API ─────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ─── Auth ────────────────────────────────────────────────────────────────────
# JWT secret for dashboard sessions (generate: openssl rand -base64 32)
JWT_SECRET=changeme-generate-a-real-secret-before-production

# ─── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=pgag-api

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── Seed API Keys (demo only — rotate in production) ────────────────────────
SEED_TENANT_API_KEY=demo-tenant-key-acme
SEED_ADMIN_API_KEY=demo-admin-key-internal
